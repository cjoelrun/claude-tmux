#!/usr/bin/env bash
set -euo pipefail

GREEN=$'\033[32m'
YELLOW=$'\033[33m'
DIM=$'\033[2m'
BOLD=$'\033[1m'
RESET=$'\033[0m'

FOCUS_FILE="${XDG_DATA_HOME:-$HOME/.local/share}/claudemacs/focused"
PROJECTS_FILE="${XDG_DATA_HOME:-$HOME/.local/share}/claudemacs/projects"
REMOTE_HOSTS_FILE="${XDG_DATA_HOME:-$HOME/.local/share}/claudemacs/remote-hosts"
PROJECT_PATHS_FILE="${XDG_DATA_HOME:-$HOME/.local/share}/claudemacs/project-paths"

# Prefix for remote SSH commands — non-interactive SSH doesn't load the login
# shell profile, so tmux/claude may not be on PATH.
_RENV='export PATH="$PATH:/usr/local/bin:/opt/homebrew/bin:/home/linuxbrew/.linuxbrew/bin";'

die() { printf 'error: %s\n' "$*" >&2; exit 1; }

_is_focused() {
    [ -f "$FOCUS_FILE" ] && grep -qxF "$1" "$FOCUS_FILE"
}

_toggle_focus() {
    local target="$1"
    mkdir -p "$(dirname "$FOCUS_FILE")"
    if _is_focused "$target"; then
        grep -vxF "$target" "$FOCUS_FILE" > "$FOCUS_FILE.tmp" && mv "$FOCUS_FILE.tmp" "$FOCUS_FILE"
    else
        echo "$target" >> "$FOCUS_FILE"
    fi
}

# Shared Claude status detection. Defines classify_status() which reads a tmux
# target name and echoes one of: running, waiting, idle, process, or "" (not a
# claude session). Embedded in remote SSH payloads so local and remote use the
# exact same rules.
_STATUS_DETECT_SNIPPET='
classify_status() {
    local target="$1"
    local tail last
    tail=$(tmux capture-pane -t "$target" -p -S -50 2>/dev/null) || return
    tail=$(printf "%s\n" "$tail" | tail -20 | sed "/^$/d" | tail -10)
    last=$(printf "%s\n" "$tail" | tail -1)
    if printf "%s" "$last" | grep -qE "esc to interrupt|ctrl\+c to interrupt"; then
        echo running
    elif printf "%s" "$last" | grep -qE "\[[Yy]/[Nn]\]|Enter to select.*Esc to cancel|Esc to cancel|ctrl-g to edit in VS Code|\(esc\)$"; then
        echo waiting
    elif printf "%s" "$tail" | grep -qE "⏺|❯|Enter to select|Ready to submit"; then
        if printf "%s" "$tail" | grep -qE "❯ [0-9]+\.|Ready to submit"; then
            echo waiting
        else
            echo idle
        fi
    else
        echo process
    fi
}
'
eval "$_STATUS_DETECT_SNIPPET"

# Local callers used to name this _detect_status; keep an alias to avoid churn.
_detect_status() { classify_status "$1"; }

# Sort raw task lines and insert a separator between focused and unfocused items.
# Reads tab-delimited lines on stdin (sort_order in field 4), outputs fields 1-3.
_sort_with_separator() {
    sort -t$'\t' -k3 -n -s | {
        local saw_focused=false sep_done=false
        while IFS=$'\t' read -r f1 f2 f3 rest; do
            if [ "${f3:-0}" -lt 0 ]; then
                saw_focused=true
            elif $saw_focused && ! $sep_done; then
                sep_done=true
                printf '%s\t%s\n' "separator:" "${DIM}──────────────────────────────────────────────${RESET}"
            fi
            printf '%s\t%s\n' "$f1" "$f2"
        done
    }
}

# --- Status line ---

REMOTE_STATUS_FILE="${XDG_DATA_HOME:-$HOME/.local/share}/claudemacs/remote-status"
REMOTE_STATUS_LOCK="${XDG_DATA_HOME:-$HOME/.local/share}/claudemacs/remote-status.lock"
REMOTE_STATUS_TTL=30

_status_line_fetch_remote() {
    # Lock to prevent concurrent fetches
    if ! mkdir "$REMOTE_STATUS_LOCK" 2>/dev/null; then
        return 0
    fi
    trap "rmdir '$REMOTE_STATUS_LOCK' 2>/dev/null" EXIT

    local peers
    peers=$(_remote_peers)
    if [ -z "$peers" ]; then
        printf 'waiting=0\nrunning=0\nidle=0\n' > "$REMOTE_STATUS_FILE"
        return 0
    fi

    # SSH into each host and count statuses
    local tmpout
    tmpout=$(mktemp "${TMPDIR:-/tmp}/claudemacs-rstatus.XXXXXX")
    local pids=()
    while IFS=$'\t' read -r ip hostname; do
        ssh -o ConnectTimeout=2 -o BatchMode=yes "$ip" \
            "${_RENV}${_STATUS_DETECT_SNIPPET}"'
w=0; r=0; i=0
for s in $(tmux list-sessions -F "#{session_name}" 2>/dev/null); do
    while IFS= read -r line; do
        target="${line%%@@*}"; cmd=$(printf "%s" "$line" | cut -d"@@" -f4)
        if printf "%s" "$cmd" | grep -qE "^(bash|zsh|fish|sh|dash)$"; then
            i=$((i+1))
        else
            case "$(classify_status "$target")" in
                running) r=$((r+1)) ;;
                waiting) w=$((w+1)) ;;
                idle)    i=$((i+1)) ;;
            esac
        fi
    done <<EOF
$(tmux list-windows -t "=$s" -F "#{session_name}:#{window_index}@@${s}@@#{window_name}@@#{pane_current_command}" 2>/dev/null)
EOF
done
printf "%d %d %d\n" "$w" "$r" "$i"' >> "$tmpout" 2>/dev/null &
        pids+=($!)
    done <<< "$peers"
    for pid in "${pids[@]}"; do
        wait "$pid" 2>/dev/null || true
    done

    # Sum counts from all hosts
    local tw=0 tr=0 ti=0
    while read -r w r i; do
        tw=$((tw + w)); tr=$((tr + r)); ti=$((ti + i))
    done < "$tmpout"
    rm -f "$tmpout"

    mkdir -p "$(dirname "$REMOTE_STATUS_FILE")"
    printf 'waiting=%d\nrunning=%d\nidle=%d\n' "$tw" "$tr" "$ti" > "$REMOTE_STATUS_FILE"
}

_status_line() {
    local waiting=0 running=0 idle=0

    # Build proxy session set
    local _proxy_list=""
    local _s
    while IFS= read -r _s; do
        if tmux show-environment -t "=$_s" CLAUDEMACS_PROXY 2>/dev/null | grep -q '='; then
            _proxy_list="${_proxy_list}|${_s}"
        fi
    done < <(tmux list-sessions -F '#{session_name}' 2>/dev/null)

    # Load focus set — only show focused tasks in status line
    local _focused_list=""
    [ -f "$FOCUS_FILE" ] && _focused_list=$(<"$FOCUS_FILE")

    local _all_windows
    _all_windows=$(tmux list-windows -a -F "#{session_name}:#{window_index}	#{session_name}	#{pane_current_command}" 2>/dev/null) || return 0
    [ -z "$_all_windows" ] && return 0

    while IFS=$'\t' read -r target sess cmd; do
        [ -z "$target" ] && continue
        [[ "$_proxy_list" == *"|${sess}"* ]] && continue
        # Skip non-focused tasks when focus list is non-empty
        if [ -n "$_focused_list" ] && [[ $'\n'"$_focused_list"$'\n' != *$'\n'"$target"$'\n'* ]]; then
            continue
        fi
        if [[ "$cmd" =~ ^(bash|zsh|fish|sh|dash)$ ]]; then
            ((idle++))
            continue
        fi

        local st
        st=$(_detect_status "$target")
        case "$st" in
            running) ((running++)) ;;
            waiting) ((waiting++)) ;;
            idle)    ((idle++)) ;;
        esac
    done <<< "$_all_windows"

    # Merge remote counts from cache, refresh in background if stale
    # Skip remote counts when focus is active (remote tasks aren't focus-filtered)
    if [ -z "$_focused_list" ] && [ -f "$REMOTE_STATUS_FILE" ]; then
        while IFS='=' read -r key val; do
            case "$key" in
                waiting) waiting=$((waiting + val)) ;;
                running) running=$((running + val)) ;;
                idle)    idle=$((idle + val)) ;;
            esac
        done < "$REMOTE_STATUS_FILE"
        # Check staleness (macOS stat)
        local mtime now age
        mtime=$(stat -f%m "$REMOTE_STATUS_FILE" 2>/dev/null || stat -c%Y "$REMOTE_STATUS_FILE" 2>/dev/null) || mtime=0
        now=$(date +%s)
        age=$((now - mtime))
        if [ "$age" -ge "$REMOTE_STATUS_TTL" ]; then
            _status_line_fetch_remote &
            disown 2>/dev/null
        fi
    elif [ -z "$_focused_list" ] && command -v tailscale >/dev/null 2>&1; then
        # No cache yet, kick off first fetch
        _status_line_fetch_remote &
        disown 2>/dev/null
    fi

    local out=""
    [ "$waiting" -gt 0 ] && out="#[fg=yellow]◎ ${waiting}#[default] "
    [ "$idle" -gt 0 ] && out="${out}#[fg=yellow]○ ${idle}#[default] "
    [ "$running" -gt 0 ] && out="${out}#[fg=green]● ${running}#[default] "
    printf '%s' "$out"
}

# --- Queries ---

_sessions() {
    tmux list-sessions -F '#{session_name}' 2>/dev/null | while IFS= read -r s; do
        tmux show-environment -t "=$s" CLAUDEMACS_PROXY 2>/dev/null | grep -q '=' || echo "$s"
    done || true
}

_projects() {
    # Merge live tmux sessions, persisted projects, and discovered git repos
    local seen=()
    local seen_list=""
    # First, live sessions (they have current path)
    local sessions
    sessions=$(_sessions)
    if [ -n "$sessions" ]; then
        while IFS= read -r s; do
            local path
            path=$(tmux display-message -t "$s" -p '#{session_path}')
            printf '%s\t%s\n' "$s" "$path"
            seen+=("$s")
            seen_list="${seen_list}${s}"$'\n'
        done <<< "$sessions"
    fi
    # Then, persisted projects not currently live
    if [ -f "$PROJECTS_FILE" ]; then
        while IFS=$'\t' read -r name path; do
            local found=0
            for s in "${seen[@]:-}"; do
                [ "$s" = "$name" ] && { found=1; break; }
            done
            if [ "$found" -eq 0 ]; then
                printf '%s\t%s\n' "$name" "$path"
                seen_list="${seen_list}${name}"$'\n'
            fi
        done < "$PROJECTS_FILE"
    fi
    # Finally, discovered projects from configured scan directories
    _discover_projects "$seen_list"
}

_save_project() {
    local name="$1" path="$2"
    mkdir -p "$(dirname "$PROJECTS_FILE")"
    # Remove existing entry for this name, then append
    if [ -f "$PROJECTS_FILE" ]; then
        grep -v "^${name}"$'\t' "$PROJECTS_FILE" > "${PROJECTS_FILE}.tmp" || true
        mv "${PROJECTS_FILE}.tmp" "$PROJECTS_FILE"
    fi
    printf '%s\t%s\n' "$name" "$path" >> "$PROJECTS_FILE"
}

_discover_projects() {
    local seen="$1"  # newline-separated session names to skip
    [ -f "$PROJECT_PATHS_FILE" ] || return 0
    while IFS= read -r dir; do
        [[ "$dir" =~ ^#|^$ ]] && continue
        dir="${dir/#\~/$HOME}"
        [ -d "$dir" ] || continue
        find "$dir" -maxdepth 3 -name .git -type d 2>/dev/null | while read -r gitdir; do
            local path="${gitdir%/.git}"
            local name="${path##*/}"
            # Skip if already seen (live or persisted)
            echo "$seen" | grep -qxF "$name" && continue
            printf '%s\t%s\n' "$name" "$path"
        done
    done < "$PROJECT_PATHS_FILE"
}

_tasks() {
    # Build proxy session set: collect session names that have CLAUDEMACS_PROXY env
    local _proxy_list=""
    local _s
    while IFS= read -r _s; do
        if tmux show-environment -t "=$_s" CLAUDEMACS_PROXY 2>/dev/null | grep -q '='; then
            _proxy_list="${_proxy_list}|${_s}"
        fi
    done < <(tmux list-sessions -F '#{session_name}' 2>/dev/null)

    # Single list-windows -a call, exclude proxy sessions
    local _all_windows
    _all_windows=$(tmux list-windows -a -F "#{session_name}:#{window_index}	#{session_name}	#{window_name}	#{pane_current_command}	#{window_activity}" 2>/dev/null) || return 0
    [ -z "$_all_windows" ] && return 0

    # Load focus set once into a newline-separated string for matching
    local _focused_list=""
    if [ -f "$FOCUS_FILE" ]; then
        _focused_list=$(<"$FOCUS_FILE")
    fi

    # Exclude proxy sessions
    local _filtered=""
    while IFS=$'\t' read -r _target _sess _wname _cmd _activity; do
        [[ "$_proxy_list" == *"|${_sess}"* ]] && continue
        _filtered="${_filtered}${_target}	${_sess}	${_wname}	${_cmd}	${_activity}
"
    done <<< "$_all_windows"
    [ -z "$_filtered" ] && return 0

    while IFS=$'\t' read -r target project name cmd activity; do
        [ -z "$target" ] && continue
        local status icon color sort_order
        if [[ "$cmd" =~ ^(bash|zsh|fish|sh|dash)$ ]]; then
            status="idle" icon="○" color="$YELLOW" sort_order=1
        else
            local st
            st=$(_detect_status "$target")
            case "$st" in
                running) status="running" icon="●" color="$GREEN" sort_order=2 ;;
                waiting) status="waiting" icon="◎" color="$YELLOW" sort_order=0 ;;
                idle)    status="idle" icon="○" color="$YELLOW" sort_order=1 ;;
                *)       status="process" icon="⚙" color="$DIM" sort_order=3 ;;
            esac
        fi
        # Check focus via string match (avoids per-task grep)
        local is_focused=false
        if [ -n "$_focused_list" ] && [[ $'\n'"$_focused_list"$'\n' == *$'\n'"$target"$'\n'* ]]; then
            sort_order=$(( sort_order - 10 ))
            is_focused=true
        fi
        local pane_text
        pane_text=$(tmux capture-pane -t "$target" -p -S -50 2>/dev/null | tr '\n' ' ' | tr '\t' ' ')
        local proj_col=15 name_col=20
        # Truncate long names
        [ ${#project} -gt $proj_col ] && project="${project:0:$((proj_col-1))}…"
        [ ${#name} -gt $name_col ] && name="${name:0:$((name_col-1))}…"
        local proj_pad=$(( proj_col - ${#project} ))
        local name_pad=$(( name_col - ${#name} ))
        local label status_str pad
        label="${project}$(printf '%*s' "$proj_pad" '')${name}$(printf '%*s' "$name_pad" '')"
        if $is_focused; then
            status_str="${icon} ${status} ★"
        else
            status_str="${icon} ${status}"
        fi
        local list_width=46
        local pad_len=$(( list_width - ${#label} - ${#status_str} ))
        [ "$pad_len" -lt 1 ] && pad_len=1
        pad=$(printf '%*s' "$pad_len" '')
        printf '%s\t%s%s%s%s%s%s%s\t%s\t%s\n' \
            "$target" "$DIM" "$label" "$RESET" "$pad" "$color" "$status_str" "$RESET" "$sort_order" "$pane_text"
    done < <(printf '%s' "$_filtered" | sort -t$'\t' -k5 -rn)
}

_remote_peers() {
    command -v tailscale >/dev/null 2>&1 || return 0
    local json
    json=$(tailscale status --json 2>/dev/null) || return 0

    # Build whitelist filter for jq/python
    # Only use whitelist if file exists and has non-comment, non-blank lines
    local whitelist_arg=""
    if [ -f "$REMOTE_HOSTS_FILE" ] && grep -qv '^#\|^$' "$REMOTE_HOSTS_FILE"; then
        whitelist_arg="$REMOTE_HOSTS_FILE"
    fi

    if command -v jq >/dev/null 2>&1; then
        # Build jq whitelist filter
        local jq_filter
        if [ -n "$whitelist_arg" ]; then
            # Read whitelist into a jq array, filtering comments and blanks
            local wl_json
            wl_json=$(grep -v '^#' "$whitelist_arg" | grep -v '^$' | jq -R . | jq -s .)
            jq_filter='(.Peer // {}) | to_entries[].value
                | select(.Online == true)
                | select(.OS != null and .OS != "" and .OS != "iOS" and .OS != "android")
                | select(.TailscaleIPs | length > 0)
                | ((.HostName // (.DNSName // "unknown")) | split(".")[0]) as $host
                | select('"$wl_json"' | index($host))
                | "\(.TailscaleIPs[0])\t\($host)"'
        else
            jq_filter='(.Peer // {}) | to_entries[].value
                | select(.Online == true)
                | select(.OS != null and .OS != "" and .OS != "iOS" and .OS != "android")
                | select(.TailscaleIPs | length > 0)
                | "\(.TailscaleIPs[0])\t\((.HostName // (.DNSName // "unknown")) | split(".")[0])"'
        fi
        printf '%s' "$json" | jq -r "$jq_filter" 2>/dev/null || true
    else
        # Fallback to python3
        printf '%s' "$json" | python3 -c '
import sys, json, os

whitelist_file = sys.argv[1] if len(sys.argv) > 1 else None
whitelist = None
if whitelist_file and os.path.exists(whitelist_file):
    with open(whitelist_file) as f:
        whitelist = set(line.strip() for line in f if line.strip() and not line.startswith("#"))

data = json.load(sys.stdin)
peers = data.get("Peer", {})
for key, peer in peers.items():
    if not peer.get("Online", False):
        continue
    os_name = peer.get("OS", "")
    if not os_name or os_name in ("iOS", "android"):
        continue
    ips = peer.get("TailscaleIPs", [])
    if not ips:
        continue
    hostname = peer.get("HostName", peer.get("DNSName", "unknown")).split(".")[0]

    if whitelist and hostname not in whitelist:
        continue

    print(f"{ips[0]}\t{hostname}")
' "$whitelist_arg" 2>/dev/null || true
    fi
}

_host_picker() {
    local lines
    lines=$(printf 'local\tlocal\n')
    local peers
    peers=$(_remote_peers)
    if [ -n "$peers" ]; then
        lines="${lines}"$'\n'"${peers}"
    fi
    printf '%s\n' "$lines" | fzf --ansi --layout=reverse \
        --delimiter '\t' --with-nth 2 \
        --header 'Select host' | head -1
}

_remote_projects_for_host() {
    local ip="$1" hostname="$2"
    local raw
    raw=$(ssh -o ConnectTimeout=2 -o BatchMode=yes "$ip" \
        "${_RENV} for s in \$(tmux list-sessions -F '#{session_name}' 2>/dev/null); do printf '%s\\t%s\\n' \"\$s\" \"\$(tmux display-message -t \"=\$s\" -p '#{session_path}')\"; done" 2>/dev/null) || return 0
    [ -z "$raw" ] && return 0
    while IFS=$'\t' read -r session_name session_path; do
        printf 'remote:%s:%s\t%s\t%s\n' "$ip" "$hostname" "$session_name" "$session_path"
    done <<< "$raw"
}

_all_projects() {
    local projects
    projects=$(_projects)
    if [ -n "$projects" ]; then
        while IFS=$'\t' read -r proj path; do
            printf 'local\t%s\t%s\n' "$proj" "$path"
        done <<< "$projects"
    fi
    local peers
    peers=$(_remote_peers)
    [ -z "$peers" ] && return 0
    local pids=()
    local tmpfile
    tmpfile=$(mktemp "${TMPDIR:-/tmp}/claudemacs-allproj.XXXXXX")
    while IFS=$'\t' read -r ip hostname; do
        _remote_projects_for_host "$ip" "$hostname" >> "$tmpfile" &
        pids+=($!)
    done <<< "$peers"
    for pid in "${pids[@]}"; do
        wait "$pid" 2>/dev/null || true
    done
    [ -f "$tmpfile" ] && cat "$tmpfile"
    rm -f "$tmpfile"
}

_remote_tasks_for_host() {
    local ip="$1" hostname="$2"
    local raw
    raw=$(ssh -o ConnectTimeout=2 -o BatchMode=yes "$ip" \
        "${_RENV}${_STATUS_DETECT_SNIPPET}"'
for s in $(tmux list-sessions -F "#{session_name}" 2>/dev/null); do
    tmux list-windows -t "=$s" -F "#{session_name}:#{window_index}@@${s}@@#{window_name}@@#{pane_current_command}@@#{window_activity}" 2>/dev/null | while IFS= read -r line; do
        target="${line%%@@*}"
        cmd=$(printf "%s" "$line" | awk -F "@@" "{print \$4}")
        if printf "%s" "$cmd" | grep -qE "^(bash|zsh|fish|sh|dash)$"; then
            st="idle"
        else
            st=$(classify_status "$target")
            [ -z "$st" ] && st="process"
        fi
        printf "%s@@%s\n" "$line" "$st"
    done
done' 2>/dev/null) || return 0
    [ -z "$raw" ] && return 0
    raw=$(printf '%s' "$raw" | awk -F'@@' -v OFS='\t' '{$1=$1; print}')
    [ -z "$raw" ] && return 0
    echo "$raw" | sort -t$'\t' -k5 -rn | while IFS=$'\t' read -r target project name cmd activity status; do
        local icon color sort_order
        case "$status" in
            running) icon="●" color="$GREEN" sort_order=2 ;;
            waiting) icon="◎" color="$YELLOW" sort_order=0 ;;
            idle)    icon="○" color="$YELLOW" sort_order=1 ;;
            *)       status="process" icon="⚙" color="$DIM" sort_order=3 ;;
        esac
        local is_focused=false
        if _is_focused "remote:${ip}:${target}"; then
            sort_order=$(( sort_order - 10 ))
            is_focused=true
        fi
        local remote_target="remote:${ip}:${target}"
        local proj_col=15 name_col=20
        # Truncate long names
        [ ${#project} -gt $proj_col ] && project="${project:0:$((proj_col-1))}…"
        [ ${#name} -gt $name_col ] && name="${name:0:$((name_col-1))}…"
        local proj_pad=$(( proj_col - ${#project} ))
        local name_pad=$(( name_col - ${#name} ))
        local host_tag="${DIM}↗${RESET}"
        local label="${project}$(printf '%*s' "$proj_pad" '')${name}$(printf '%*s' "$name_pad" '')"
        if $is_focused; then
            local status_str="${icon} ${status} ★"
        else
            local status_str="${icon} ${status}"
        fi
        local list_width=46
        local pad_len=$(( list_width - ${#label} - ${#status_str} ))
        [ "$pad_len" -lt 1 ] && pad_len=1
        local pad
        pad=$(printf '%*s' "$pad_len" '')
        printf '%s\t%s%s%s%s%s%s%s %s\t%s\n' \
            "$remote_target" "$DIM" "$label" "$RESET" "$pad" "$color" "$status_str" "$RESET" "$host_tag" "$sort_order"
    done
}

_fetch_remote() {
    local outfile="$1"
    local peers
    peers=$(_remote_peers)
    [ -z "$peers" ] && { : > "$outfile"; return 0; }
    local tmpout="${outfile}.fetching"
    : > "$tmpout"
    local pids=()
    while IFS=$'\t' read -r ip hostname; do
        _remote_tasks_for_host "$ip" "$hostname" >> "$tmpout" &
        pids+=($!)
    done <<< "$peers"
    for pid in "${pids[@]}"; do
        wait "$pid" 2>/dev/null || true
    done
    mv "$tmpout" "$outfile"
}

_merge_caches() {
    local local_cache="$1" remote_cache="$2"
    { cat "$local_cache" 2>/dev/null; cat "$remote_cache" 2>/dev/null; } | _sort_with_separator
}

_refresh_and_merge() {
    local local_cache="$1" remote_cache="$2"
    _tasks > "$local_cache"
    { cat "$local_cache"; [ -f "$remote_cache" ] && cat "$remote_cache"; } | _sort_with_separator
    return 0
}

_focus_and_refresh() {
    local target="$1" local_cache="$2" remote_cache="$3"
    _toggle_focus "$target"
    _tasks > "$local_cache"
    # Update remote cache if target is remote (toggle focus sort_order)
    if [[ "$target" == remote:* ]] && [ -f "$remote_cache" ]; then
        local tmpfile="${remote_cache}.tmp"
        while IFS= read -r line; do
            if [[ "$line" == "${target}"$'\t'* ]]; then
                if _is_focused "$target"; then
                    # Subtract 10 from current sort_order to move to focused range
                    local cur_so; cur_so=$(echo "$line" | sed -E 's/.*	([0-9-]+)$/\1/')
                    line=$(echo "$line" | sed -E "s/	[0-9-]+$/	$(( cur_so - 10 ))/")
                else
                    # Add 10 to restore original sort_order
                    local cur_so; cur_so=$(echo "$line" | sed -E 's/.*	([0-9-]+)$/\1/')
                    line=$(echo "$line" | sed -E "s/	[0-9-]+$/	$(( cur_so + 10 ))/")
                fi
            fi
            printf '%s\n' "$line"
        done < "$remote_cache" > "$tmpfile"
        mv "$tmpfile" "$remote_cache"
    fi
    { cat "$local_cache"; [ -f "$remote_cache" ] && cat "$remote_cache"; } | _sort_with_separator
}

_kill_and_refresh() {
    local target="$1" local_cache="$2" remote_cache="$3"
    _kill_task "$target"
    # Wait for tmux to reflect the kill (up to 2s)
    local i=0
    while [ "$i" -lt 20 ]; do
        if [[ "$target" == remote:* ]]; then
            local rest="${target#remote:}"
            local ip="${rest%%:*}"
            local remote_ref="${rest#*:}"
            ssh -o ConnectTimeout=2 -o BatchMode=yes "$ip" \
                "${_RENV} tmux list-windows -t '=${remote_ref%%:*}' -F '#{session_name}:#{window_index}'" 2>/dev/null \
                | grep -qxF "$remote_ref" || break
        else
            tmux list-windows -t "=${target%%:*}" -F '#{session_name}:#{window_index}' 2>/dev/null \
                | grep -qxF "$target" || break
        fi
        sleep 0.1
        i=$((i + 1))
    done
    _tasks > "$local_cache"
    { cat "$local_cache"; [ -f "$remote_cache" ] && cat "$remote_cache"; } | _sort_with_separator
}

_preview() {
    local target="${1:-}"
    [ -z "$target" ] && return
    [[ "$target" == separator:* ]] && return
    if [[ "$target" == remote:* ]]; then
        local rest="${target#remote:}"
        local ip="${rest%%:*}"
        local remote_ref="${rest#*:}"
        ssh -o ConnectTimeout=2 -o BatchMode=yes "$ip" \
            "${_RENV} tmux capture-pane -t '$remote_ref' -p -S -50 2>/dev/null" 2>/dev/null || echo "(no output)"
    else
        tmux capture-pane -t "$target" -p -S -50 2>/dev/null || echo "(no output)"
    fi
}

# --- Actions ---

_switch() {
    local target="${1:-}" display_name="${2:-}"
    [ -z "$target" ] && return
    [[ "$target" == loading:* || "$target" == separator:* ]] && return
    if [[ "$target" == remote:* ]]; then
        local rest="${target#remote:}"
        local ip="${rest%%:*}"
        local remote_ref="${rest#*:}"
        local session="${remote_ref%%:*}"
        local win_idx="${remote_ref##*:}"

        # Set ctrl-a prefix and select the target window on remote
        ssh -o ConnectTimeout=2 -o BatchMode=yes "$ip" \
            "${_RENV} tmux set-option -t '=${session}' prefix C-a; tmux select-window -t '=${session}:${win_idx}'" 2>/dev/null

        # Ensure a local proxy session exists
        local ssh_cmd="ssh -t $ip '${_RENV} tmux set-option -t \"=${session}\" prefix C-a; tmux attach -t \"=${session}\"'"
        local proxy_target="=${session}:${win_idx}"
        if ! tmux has-session -t "=$session" 2>/dev/null; then
            tmux new-session -d -s "$session" -n "$win_idx"
            tmux set-environment -t "=$session" CLAUDEMACS_PROXY 1
            tmux set-option -t "$session" @claudemacs_proxy 1
            tmux send-keys -t "$proxy_target" "$ssh_cmd" Enter
        else
            # Ensure proxy session is tagged for passthrough detection
            tmux set-option -q -t "$session" @claudemacs_proxy 1
            # Create window in proxy if it doesn't exist
            if ! tmux list-windows -t "=$session" -F '#{window_index}' | grep -qx "$win_idx"; then
                tmux new-window -t "=${session}" -n "$win_idx"
            fi
            # Reconnect if SSH died (pane fell back to shell or shows disconnection)
            local pane_cmd pane_content
            pane_cmd=$(tmux display-message -t "$proxy_target" -p '#{pane_current_command}' 2>/dev/null)
            pane_content=$(tmux capture-pane -t "$proxy_target" -p -S -5 2>/dev/null)
            if echo "$pane_cmd" | grep -qE '^(bash|zsh|fish|sh|dash)$' || \
               echo "$pane_content" | grep -qiE 'connection (closed|reset|timed out)|broken pipe'; then
                tmux send-keys -t "$proxy_target" "$ssh_cmd" Enter
            fi
        fi

        if [ -n "${TMUX:-}" ]; then
            tmux select-window -t "$proxy_target"
            tmux switch-client -t "=$session"
        else
            tmux attach -t "$proxy_target"
        fi
    elif [ -n "${TMUX:-}" ]; then
        tmux switch-client -t "$target"
    else
        tmux attach -t "$target"
    fi
}

_rename_task() {
    local target="${1:-}"
    [ -z "$target" ] && return
    local current_name
    if [[ "$target" == remote:* ]]; then
        local rest="${target#remote:}"
        local ip="${rest%%:*}"
        local remote_ref="${rest#*:}"
        current_name=$(ssh -o ConnectTimeout=2 -o BatchMode=yes "$ip" \
            "${_RENV} tmux display-message -t '$remote_ref' -p '#{window_name}'" 2>/dev/null)
    else
        current_name=$(tmux display-message -t "$target" -p '#{window_name}' 2>/dev/null)
    fi
    local new_name
    read -rp "Rename [${current_name}]: " new_name
    [ -z "$new_name" ] && return
    if [[ "$target" == remote:* ]]; then
        local rest="${target#remote:}"
        local ip="${rest%%:*}"
        local remote_ref="${rest#*:}"
        ssh -o ConnectTimeout=2 -o BatchMode=yes "$ip" \
            "${_RENV} tmux rename-window -t '$remote_ref' '$new_name'" 2>/dev/null
    else
        tmux rename-window -t "$target" "$new_name"
    fi
}

_kill_task() {
    local target="${1:-}"
    [ -z "$target" ] && return
    if [[ "$target" == remote:* ]]; then
        local rest="${target#remote:}"
        local ip="${rest%%:*}"
        local remote_ref="${rest#*:}"
        local session="${remote_ref%%:*}"
        local win_idx="${remote_ref##*:}"
        # Kill remote window
        ssh -o ConnectTimeout=2 -o BatchMode=yes "$ip" \
            "${_RENV} tmux kill-window -t '$remote_ref'" 2>/dev/null || true
        # Kill corresponding local proxy window if it exists
        tmux kill-window -t "=${session}:${win_idx}" 2>/dev/null || true
    else
        tmux kill-window -t "$target" 2>/dev/null || true
    fi
}

_pick_command() {
    local commands=(
        "claude"
        "sh"
        "emacs -nw"
        "nvim"
        "btop"
        "htop"
        "lazygit"
        "tig"
    )

    local result
    result=$(printf '%s\n' "${commands[@]}" | fzf \
        --prompt 'Command: ' \
        --height 40% \
        --layout=reverse \
        --header 'Enter: select · Ctrl-e: use custom command · Esc: shell' \
        --query="claude" \
        --print-query \
        --bind 'ctrl-e:replace-query+print-query+accept')

    # Parse fzf output: last non-empty line is the selection or custom command
    local cmd
    cmd=$(echo "$result" | grep -v '^$' | tail -1)

    # Return empty string for explicit "sh" choice, otherwise return the command
    if [ "$cmd" = "sh" ]; then
        echo ""
    else
        echo "$cmd"
    fi
}

_ensure_passthrough_bindings() {
    local self
    self=$(cd "$(dirname "$0")" && pwd)/$(basename "$0")
    # F12 toggles between normal and passthrough
    tmux bind -T root F12 \
        set key-table off \;\
        set status-style "bg=colour236" \;\
        refresh-client -S
    tmux bind -T off F12 \
        set -u key-table \;\
        set -u status-style \;\
        refresh-client -S
    # Picker always opens locally, even in passthrough
    tmux bind -T off C-t display-popup -E -d '#{pane_current_path}' -w 80% -h 80% "$self"
    # Auto-passthrough: on every session change, detect proxy sessions
    # via @claudemacs_proxy option and toggle key-table accordingly.
    tmux set-hook -g 'client-session-changed[42]' \
        "if-shell -F '#{@claudemacs_proxy}' \
            'set key-table off ; set status-style bg=colour236 ; refresh-client -S' \
            'set -u key-table ; set -u status-style ; refresh-client -S'"
}


_create_project() {
    local name="$1" path="$2"
    name=$(echo "$name" | tr -cd 'a-zA-Z0-9._-')
    [ -z "$name" ] && die "invalid project name"
    [ -d "$path" ] || die "not a directory: $path"
    tmux has-session -t "=$name" 2>/dev/null && die "project already exists: $name"
    tmux new-session -d -s "$name" -c "$path" -n "shell"
    _save_project "$name" "$path"
}

_create_task() {
    local session="$1" name="$2" cmd="${3:-claude}"
    local proj_path
    # Recreate session from persisted project if needed
    if ! tmux has-session -t "=$session" 2>/dev/null; then
        if [ -f "$PROJECTS_FILE" ]; then
            proj_path=$(grep "^${session}"$'\t' "$PROJECTS_FILE" | cut -f2)
        fi
        [ -z "$proj_path" ] && die "no such session: $session"
        [ -d "$proj_path" ] || die "project directory gone: $proj_path"
        tmux new-session -d -s "$session" -c "$proj_path" -n "$name"
        local target="${session}:0"
        [ -n "$cmd" ] && tmux send-keys -t "$target" "$cmd" Enter
        echo "$target"
        return
    fi
    proj_path=$(tmux display-message -t "=$session" -p '#{session_path}')
    local idx
    idx=$(tmux new-window -t "$session" -n "$name" -c "$proj_path" -P -F '#{window_index}')
    local target="${session}:${idx}"
    [ -n "$cmd" ] && tmux send-keys -t "$target" "$cmd" Enter
    echo "$target"
}

_create_project_remote() {
    local ip="$1" name="$2" path="$3"
    name=$(echo "$name" | tr -cd 'a-zA-Z0-9._-')
    [ -z "$name" ] && die "invalid project name"
    ssh -o ConnectTimeout=5 -o BatchMode=yes "$ip" \
        "${_RENV} tmux new-session -d -s '${name}' -c '${path}' -n 'shell' && tmux set-option -t '=${name}' prefix C-a" \
        || die "failed to create remote project on $ip"
}

_create_task_remote() {
    local ip="$1" session="$2" task_name="$3" cmd="${4:-claude}"
    local idx
    local send_keys_cmd=""
    [ -n "$cmd" ] && send_keys_cmd="&& tmux send-keys -t '\${session}:'\"\$idx\" '${cmd}' Enter"
    idx=$(ssh -o ConnectTimeout=5 -o BatchMode=yes "$ip" \
        "${_RENV} proj_path=\$(tmux display-message -t '=${session}' -p '#{session_path}') && idx=\$(tmux new-window -t '${session}' -n '${task_name}' -c \"\$proj_path\" -P -F '#{window_index}') ${send_keys_cmd} && echo \"\$idx\"") \
        || die "failed to create remote task on $ip"
    idx=$(echo "$idx" | tr -d '[:space:]')
    echo "remote:${ip}:${session}:${idx}"
}

# --- Path Pickers ---

_path_picker_local() {
    find "$HOME" -maxdepth 3 -type d \
        -not -path '*/\.*' -not -path '*/node_modules/*' 2>/dev/null |
    fzf --layout=reverse --scheme=path \
        --prompt 'Path: ' --query "$(pwd)" \
        --print-query | tail -1
}

_path_picker_remote() {
    local ip="$1"
    ssh -o ConnectTimeout=5 -o BatchMode=yes "$ip" \
        "${_RENV} find \$HOME -maxdepth 3 -type d \
            -not -path '*/\\.*' -not -path '*/node_modules/*' 2>/dev/null" |
    fzf --layout=reverse --scheme=path \
        --prompt 'Remote path: ' \
        --print-query | tail -1
}

# --- Project Path Management ---

_add_path() {
    local dir="${1:-}"
    [ -z "$dir" ] && die "usage: claudemacs add-path <directory>"
    dir="${dir/#\~/$HOME}"
    [ -d "$dir" ] || die "not a directory: $dir"
    # Resolve to absolute path
    dir=$(cd "$dir" && pwd)
    mkdir -p "$(dirname "$PROJECT_PATHS_FILE")"
    # Dedup: skip if already present (ignoring comments/blanks)
    if [ -f "$PROJECT_PATHS_FILE" ]; then
        while IFS= read -r line; do
            [[ "$line" =~ ^#|^$ ]] && continue
            local expanded="${line/#\~/$HOME}"
            [ -d "$expanded" ] && expanded=$(cd "$expanded" && pwd)
            [ "$expanded" = "$dir" ] && { echo "already configured: $dir"; return 0; }
        done < "$PROJECT_PATHS_FILE"
    fi
    echo "$dir" >> "$PROJECT_PATHS_FILE"
    echo "added: $dir"
}

_list_paths() {
    [ -f "$PROJECT_PATHS_FILE" ] || { echo "no project paths configured"; return 0; }
    while IFS= read -r line; do
        [[ "$line" =~ ^#|^$ ]] && continue
        echo "$line"
    done < "$PROJECT_PATHS_FILE"
}

_scan_projects() {
    _discover_projects ""
}

# --- Interactive Flows ---

_new_project_flow() {
    printf '%sNew Project%s\n\n' "$BOLD" "$RESET"

    local host_line
    host_line=$(_host_picker) || return
    [ -z "$host_line" ] && return 1

    local host_type host_ip
    host_type=$(echo "$host_line" | cut -f1)

    if [ "$host_type" = "local" ]; then
        local name path
        read -rp "Name: " name
        [ -z "$name" ] && return 1
        path=$(_path_picker_local)
        [ -z "$path" ] && return 1
        path="${path/#\~/$HOME}"
        _create_project "$name" "$path"
        printf '\nCreated project: %s → %s\n\n' "$name" "$path"
        _new_task_flow_first "$name"
    else
        host_ip="$host_type"
        local hostname
        hostname=$(echo "$host_line" | cut -f2)
        local name path
        read -rp "Name: " name
        [ -z "$name" ] && return 1
        path=$(_path_picker_remote "$host_ip")
        [ -z "$path" ] && return 1
        _create_project_remote "$host_ip" "$name" "$path"
        printf '\nCreated remote project: %s → %s on %s\n\n' "$name" "$path" "$hostname"
        _new_task_flow_first_remote "$host_ip" "$name"
    fi
}

_new_task_flow_first() {
    local project="$1"
    local task_name
    read -rp "Task name: " task_name
    [ -z "$task_name" ] && return
    local cmd
    cmd=$(_pick_command)
    local target="${project}:0"
    tmux rename-window -t "$target" "$task_name"
    [ -n "$cmd" ] && tmux send-keys -t "$target" "$cmd" Enter
    _switch "$target"
}

_new_task_flow_first_remote() {
    local ip="$1" project="$2"
    local task_name
    read -rp "Task name: " task_name
    [ -z "$task_name" ] && return
    local cmd
    cmd=$(_pick_command)
    local send_keys_cmd=""
    [ -n "$cmd" ] && send_keys_cmd="&& tmux send-keys -t '${project}:0' '${cmd}' Enter"
    ssh -o ConnectTimeout=5 -o BatchMode=yes "$ip" \
        "${_RENV} tmux rename-window -t '${project}:0' '${task_name}' ${send_keys_cmd}" \
        || die "failed to set up first task on $ip"
    local target="remote:${ip}:${project}:0"
    _switch "$target" "$task_name"
}

_new_task_flow() {
    local task_name="${1:-}"

    # Ask for task name first
    if [ -z "$task_name" ]; then
        read -rp "Task name: " task_name
        [ -z "$task_name" ] && return
    else
        printf 'Task: %s\n\n' "$task_name"
    fi

    local projects project
    projects=$(_all_projects)

    if [ -z "$projects" ]; then
        echo "No sessions yet. Create a project first."
        echo ""
        _new_project_flow || return
        echo ""
        projects=$(_all_projects)
    fi

    local selected
    printf '%sSelect session%s\n' "$BOLD" "$RESET"
    # Format: origin\tsession_name\tpath
    # Display name with dimmed [hostname] for remote entries
    local new_entry
    new_entry=$(printf 'new\t\t\t%s+ New project%s' "$GREEN" "$RESET")
    selected=$({ echo "$new_entry"; echo "$projects" | awk -F'\t' '{
        origin=$1; proj=$2; path=$3
        if (origin == "local") {
            printf "%s\t%s\t%s\t%s\n", origin, proj, path, proj
        } else {
            # origin is remote:<ip>:<hostname>
            split(origin, parts, ":")
            hostname = parts[3]
            printf "%s\t%s\t%s\t%s \033[2m[%s]\033[0m\n", origin, proj, path, proj, hostname
        }
    }'; } | fzf --ansi --delimiter '\t' --with-nth 4 \
        --preview 'echo {3}' --preview-window 'up:1:wrap') || return

    [ -z "$selected" ] && return

    local origin proj_name
    origin=$(echo "$selected" | cut -f1)
    proj_name=$(echo "$selected" | cut -f2)

    # Handle inline project creation
    if [ "$origin" = "new" ]; then
        local host_line
        host_line=$(_host_picker) || return
        [ -z "$host_line" ] && return 1

        local host_type
        host_type=$(echo "$host_line" | cut -f1)

        local new_name new_path
        read -rp "Project name: " new_name
        [ -z "$new_name" ] && return 1

        if [ "$host_type" = "local" ]; then
            new_path=$(_path_picker_local)
            [ -z "$new_path" ] && return 1
            new_path="${new_path/#\~/$HOME}"
            _create_project "$new_name" "$new_path"
            printf '\nCreated project: %s → %s\n\n' "$new_name" "$new_path"
            origin="local"
            proj_name="$new_name"
        else
            local host_ip="$host_type"
            local hostname
            hostname=$(echo "$host_line" | cut -f2)
            new_path=$(_path_picker_remote "$host_ip")
            [ -z "$new_path" ] && return 1
            _create_project_remote "$host_ip" "$new_name" "$new_path"
            printf '\nCreated remote project: %s → %s on %s\n\n' "$new_name" "$new_path" "$hostname"
            origin="remote:${host_ip}:${hostname}"
            proj_name="$new_name"
        fi
    fi

    # Pick command to run
    local cmd
    cmd=$(_pick_command)

    if [ "$origin" = "local" ]; then
        # Auto-persist discovered projects on first use
        if [ ! -f "$PROJECTS_FILE" ] || ! grep -q "^${proj_name}"$'\t' "$PROJECTS_FILE"; then
            local proj_path
            proj_path=$(echo "$selected" | cut -f3)
            [ -n "$proj_path" ] && _save_project "$proj_name" "$proj_path"
        fi
        local target
        target=$(_create_task "$proj_name" "$task_name" "$cmd")
        _switch "$target"
    else
        # origin is remote:<ip>:<hostname>
        local ip
        ip=$(echo "$origin" | cut -d: -f2)
        local target
        target=$(_create_task_remote "$ip" "$proj_name" "$task_name" "$cmd")
        _switch "$target" "$task_name"
    fi
}

_picker() {
    local self="$0"
    _ensure_passthrough_bindings
    local remote_cache local_cache fzf_sock
    remote_cache=$(mktemp "${TMPDIR:-/tmp}/claudemacs-remote.XXXXXX")
    local_cache=$(mktemp "${TMPDIR:-/tmp}/claudemacs-local.XXXXXX")
    fzf_sock="${TMPDIR:-/tmp}/claudemacs-fzf-$$.sock"
    trap "rm -f '$remote_cache' '$local_cache' '${local_cache}.tmp' '${remote_cache}.fetching' '$fzf_sock'" EXIT

    local reload_cmd="$self _merge_caches '${local_cache}' '${remote_cache}'"

    # Write loading placeholders for each remote host
    local peers
    peers=$(_remote_peers)
    if [ -n "$peers" ]; then
        while IFS=$'\t' read -r ip hostname; do
            printf 'loading:%s\t%s              ⋯ loading %s%s\t\t5\n' \
                "$ip" "$DIM" "$hostname" "$RESET"
        done <<< "$peers" > "$remote_cache"
    fi

    # Start remote fetch in parallel with local task scan;
    # POST reload to fzf when done so the list updates immediately
    ( _fetch_remote "$remote_cache"
      curl --unix-socket "$fzf_sock" -XPOST http -d "reload($reload_cmd)" 2>/dev/null || true
    ) &
    local fetch_pid=$!

    _tasks > "$local_cache"

    if [ ! -s "$local_cache" ]; then
        kill "$fetch_pid" 2>/dev/null; wait "$fetch_pid" 2>/dev/null || true
        echo "No tmux sessions."
        echo ""
        _new_project_flow || return
        _new_task_flow
        return
    fi

    # Background: refresh local task cache every 2s for live status,
    # then poke fzf to reload from both caches
    ( while sleep 2; do
        "$self" _tasks_raw > "${local_cache}.tmp" 2>/dev/null && mv "${local_cache}.tmp" "$local_cache"
        curl --unix-socket "$fzf_sock" -XPOST http -d "reload($reload_cmd)" 2>/dev/null || true
    done ) &
    local refresh_pid=$!

    _sort_with_separator < "$local_cache" | fzf --ansi \
        --listen "$fzf_sock" \
        --layout=reverse \
        --delimiter '\t' \
        --with-nth '2' \
        --footer 'alt-n:new task │ alt-o:new project │ alt-r:rename │ alt-f:focus │ ctrl-d:kill │ ctrl-g:refresh' \
        --preview "$self _preview {1}" \
        --preview-window 'right:60%:wrap:follow,<60(down:50%:wrap:follow)' \
        --bind "enter:become($self _switch {1})" \
        --bind "alt-n:execute($self new {q} < /dev/tty > /dev/tty)+abort" \
        --bind "alt-o:execute($self new-project < /dev/tty > /dev/tty)+abort" \
        --bind "alt-r:execute($self _rename_task {1} < /dev/tty > /dev/tty)+reload($self _refresh_and_merge '$local_cache' '$remote_cache')" \
        --bind "alt-f:reload($self _focus_and_refresh {1} '$local_cache' '$remote_cache')+clear-query" \
        --bind "ctrl-d:reload($self _kill_and_refresh {1} '$local_cache' '$remote_cache')" \
        --bind "ctrl-g:reload($self _refresh_and_merge '$local_cache' '$remote_cache')"
    local fzf_exit=$?

    kill "$fetch_pid" "$refresh_pid" 2>/dev/null
    wait "$fetch_pid" "$refresh_pid" 2>/dev/null || true
    return $fzf_exit
}

_setup() {
    local self
    self=$(cd "$(dirname "$0")" && pwd)/$(basename "$0")
    cat <<EOF
Add to ~/.tmux.conf:

  bind C-t display-popup -E -d '#{pane_current_path}' -w 80% -h 80% "$self"
  bind -T off C-t display-popup -E -d '#{pane_current_path}' -w 80% -h 80% "$self"

Then reload:

  tmux source-file ~/.tmux.conf
EOF
}

_usage() {
    cat <<EOF
claudemacs - tmux-native claude code session manager

Usage:
  claudemacs              Interactive picker
  claudemacs new          Create a new task
  claudemacs new-project  Create a new project
  claudemacs projects     List projects
  claudemacs add-path <dir>  Add a directory to scan for git repos
  claudemacs paths        List configured project scan directories
  claudemacs scan         Show all discovered git repo projects
  claudemacs setup        Print tmux.conf setup instructions

Keybindings (in picker):
  enter    Switch to selected task
  ctrl-n   New task
  ctrl-p   New project
  ctrl-d   Kill selected task
  esc      Close
EOF
}

# --- Entry ---

main() {
    case "${1:-}" in
        -h|--help|help) _usage ;;
        setup)          _setup ;;
        projects)       _require_tmux; _projects ;;
        add-path)       shift; _add_path "$@" ;;
        paths)          _list_paths ;;
        scan)           _scan_projects ;;
        status-line)    _require_tmux; _status_line ;;
        new)            _require_tmux; _require_fzf; shift; _new_task_flow "$*" ;;
        new-project)    _require_tmux; _require_fzf; _new_project_flow ;;
        _tasks)         _require_tmux; _tasks | _sort_with_separator ;;
        _tasks_raw)     _require_tmux; _tasks ;;
        _merge_caches)  _merge_caches "${2:-}" "${3:-}" ;;
        _refresh_and_merge) _require_tmux; _refresh_and_merge "${2:-}" "${3:-}" ;;
        _focus_and_refresh) _require_tmux; _focus_and_refresh "${2:-}" "${3:-}" "${4:-}" ;;
        _kill_and_refresh) _require_tmux; _kill_and_refresh "${2:-}" "${3:-}" "${4:-}" ;;
        _rename_task)   _require_tmux; _rename_task "${2:-}" ;;
        _preview)       _require_tmux; _preview "${2:-}" ;;
        _switch)        _require_tmux; _switch "${2:-}" ;;
        _kill)          _require_tmux; _kill_task "${2:-}" ;;
        _toggle_focus) _toggle_focus "${2:-}" ;;
        "")             _require_tmux; _require_fzf; _picker ;;
        *)              die "unknown: $1 (try --help)" ;;
    esac
}

_require_tmux() { command -v tmux >/dev/null || die "tmux required"; }
_require_fzf()  { command -v fzf >/dev/null  || die "fzf required"; }

main "$@"
